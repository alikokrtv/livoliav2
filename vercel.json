{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/theme/(.*)", "dest": "/theme/$1" },
    { "src": "/admin/assets/(.*)", "dest": "/admin/assets/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}

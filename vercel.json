{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/theme/(.*)", "dest": "/theme/$1" },
    { "src": "/admin/assets/(.*)", "dest": "/admin/assets/$1" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|map|txt|xml))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
